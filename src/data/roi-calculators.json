{
  "calculators": [
    {
      "id": "manufacturing_general",
      "name": "Manufacturing AI ROI Calculator",
      "inputs": [
        { "id": "annual_revenue", "label": "Annual Revenue (₹)", "type": "number" },
        { "id": "num_machines", "label": "Number of Machines", "type": "number" },
        { "id": "monthly_downtime_hours_per_machine", "label": "Monthly Downtime Hours per Machine", "type": "number" },
        { "id": "rejection_cost_per_year", "label": "Annual Rejection Cost (₹)", "type": "number" },
        { "id": "annual_procurement_spend", "label": "Annual Procurement Spend (₹)", "type": "number" },
        { "id": "setup_cost", "label": "AI Setup Cost (₹)", "type": "number" },
        { "id": "annual_subscription", "label": "Annual Subscription (₹)", "type": "number" }
      ],
      "computed": [
        {
          "id": "machine_hours_per_year",
          "label": "Machine Hours per Year",
          "formula": "num_machines * 24 * 365"
        },
        {
          "id": "downtime_cost_per_hour",
          "label": "Downtime Cost per Hour (₹)",
          "formula": "annual_revenue / machine_hours_per_year"
        },
        {
          "id": "annual_downtime_hours",
          "label": "Annual Downtime Hours",
          "formula": "monthly_downtime_hours_per_machine * num_machines * 12"
        },
        {
          "id": "downtime_savings",
          "label": "Downtime Savings (₹/year)",
          "formula": "downtime_cost_per_hour * annual_downtime_hours * 0.30"
        },
        {
          "id": "quality_savings",
          "label": "Quality/Rejection Savings (₹/year)",
          "formula": "rejection_cost_per_year * 0.15"
        },
        {
          "id": "procurement_savings",
          "label": "Procurement Savings (₹/year)",
          "formula": "annual_procurement_spend * 0.12"
        },
        {
          "id": "total_annual_savings",
          "label": "Total Annual Savings (₹/year)",
          "formula": "downtime_savings + quality_savings + procurement_savings"
        },
        {
          "id": "total_annual_savings_lakhs",
          "label": "Total Annual Savings (₹ Lakhs/year)",
          "formula": "total_annual_savings / 100000"
        },
        {
          "id": "monthly_savings",
          "label": "Monthly Savings (₹/month)",
          "formula": "total_annual_savings / 12"
        },
        {
          "id": "total_cost_year1",
          "label": "Total AI Cost Year 1 (₹)",
          "formula": "setup_cost + annual_subscription"
        },
        {
          "id": "payback_months",
          "label": "Payback Period (months)",
          "formula": "total_cost_year1 / monthly_savings"
        }
      ]
    },
    {
      "id": "ev_manufacturing",
      "name": "EV Manufacturing AI ROI Calculator",
      "inputs": [
        { "id": "units_per_year", "label": "Annual Production Volume (units/year)", "type": "number" },
        { "id": "asp_per_unit", "label": "Average Selling Price per Unit (₹)", "type": "number" },
        { "id": "battery_cost_per_unit", "label": "Battery Pack Cost per Unit (₹)", "type": "number" },
        { "id": "battery_scrap_rate", "label": "Battery Scrap Rate (%)", "type": "number" },
        { "id": "monthly_downtime_hours", "label": "Monthly Line Downtime Hours", "type": "number" },
        { "id": "line_hours_per_year", "label": "Line Hours per Year", "type": "number" },
        { "id": "annual_procurement_spend", "label": "Annual Procurement Spend (₹)", "type": "number" },
        { "id": "setup_cost", "label": "AI Setup Cost (₹)", "type": "number" },
        { "id": "annual_subscription", "label": "Annual Subscription (₹)", "type": "number" }
      ],
      "computed": [
        {
          "id": "annual_revenue",
          "label": "Annual Revenue (₹)",
          "formula": "units_per_year * asp_per_unit"
        },
        {
          "id": "battery_scrap_value",
          "label": "Battery Scrap Value (₹/year)",
          "formula": "battery_cost_per_unit * units_per_year * (battery_scrap_rate / 100)"
        },
        {
          "id": "battery_scrap_savings",
          "label": "Battery Scrap Savings (₹/year)",
          "formula": "battery_scrap_value * 0.12"
        },
        {
          "id": "downtime_cost_per_hour",
          "label": "Downtime Cost per Hour (₹)",
          "formula": "annual_revenue / line_hours_per_year"
        },
        {
          "id": "annual_downtime_hours",
          "label": "Annual Downtime Hours",
          "formula": "monthly_downtime_hours * 12"
        },
        {
          "id": "downtime_savings",
          "label": "Downtime Savings (₹/year)",
          "formula": "downtime_cost_per_hour * annual_downtime_hours * 0.28"
        },
        {
          "id": "procurement_savings",
          "label": "Procurement Savings (₹/year)",
          "formula": "annual_procurement_spend * 0.10"
        },
        {
          "id": "throughput_savings",
          "label": "Throughput Uplift Savings (₹/year)",
          "formula": "annual_revenue * 0.05"
        },
        {
          "id": "total_annual_savings",
          "label": "Total Annual Savings (₹/year)",
          "formula": "battery_scrap_savings + downtime_savings + procurement_savings + throughput_savings"
        },
        {
          "id": "total_annual_savings_lakhs",
          "label": "Total Annual Savings (₹ Lakhs/year)",
          "formula": "total_annual_savings / 100000"
        },
        {
          "id": "monthly_savings",
          "label": "Monthly Savings (₹/month)",
          "formula": "total_annual_savings / 12"
        },
        {
          "id": "total_cost_year1",
          "label": "Total AI Cost Year 1 (₹)",
          "formula": "setup_cost + annual_subscription"
        },
        {
          "id": "payback_months",
          "label": "Payback Period (months)",
          "formula": "total_cost_year1 / monthly_savings"
        }
      ]
    },
